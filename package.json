{
  "name": "tg-ads-kit",
  "version": "0.1.1",
  "description": "Unofficial Telegram Ads reporting API service, client, and parser toolkit.",
  "type": "module",
  "license": "MIT",
  "author": "lotfree618",
  "keywords": [
    "telegram",
    "telegram-ads",
    "ads",
    "reporting",
    "csv",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "tg-ads-kit": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js",
      "require": "./dist/api.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/server.ts",
    "prepublishOnly": "npm run test && npm run build",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lotfree618/tg-ads-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Lotfree618/tg-ads-kit/issues"
  },
  "homepage": "https://github.com/Lotfree618/tg-ads-kit#readme"
}
