# Full Cookie request header from an authenticated https://ads.telegram.org browser session.
# This is not a Telegram bot token, Cloudflare token, or TG_ADS_API_TOKEN.
TELEGRAM_ADS_COOKIE=stel_adowner=...; stel_ssid=...; stel_token=...

# Local bearer token required by the tg-ads-kit HTTP API server.
TG_ADS_API_TOKEN=replace-with-a-long-random-token

HOST=127.0.0.1
PORT=3000
